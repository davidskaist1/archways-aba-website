# ============================================================
# Archways ABA Chatbot — Environment Variables
# ============================================================
# 1. Copy this file to .env  (cp .env.example .env)
# 2. Fill in your real values
# 3. NEVER commit .env to git
# ============================================================

# ── Anthropic API Key ────────────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server Port ──────────────────────────────────────────────
# Port the chatbot server listens on (default: 3001)
PORT=3001

# ── Email / SMTP Settings ────────────────────────────────────
# Option A — Gmail (recommended for quick setup)
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to Google Account → Security → App Passwords
#   3. Create an App Password for "Mail"
#   4. Use that 16-character password as SMTP_PASS below
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Option B — Any other SMTP provider (Mailgun, SendGrid, etc.)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@mg.yourdomain.com
# SMTP_PASS=your-smtp-password

# ── Intake Notification Recipients ───────────────────────────
# Comma-separated list of email addresses that receive intake summaries
# Example: "info@archwaysaba.com,intake@archwaysaba.com"
INTAKE_EMAILS=info@archwaysaba.com
